{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "https://yeodeun.info",
      "https://www.yeodeun.info"
    ]
  },
  "Auth": {
    "Jwt": {
      "Issuer": "yeodeun-api",
      "Audience": "yeodeun-admin",
      "Key": ""
    }
  },
  "AdminEndpoints": {
    "RequireDevelopment": true,
    "AllowedIpAddresses": [
      "127.0.0.1",
      "::1"
    ]
  }
}
